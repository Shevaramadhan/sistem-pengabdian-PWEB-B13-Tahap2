<!doctype html>
<html lang="id">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Sistem Pengabdian Masyarakat - Universitas Andalas</title>
  <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg" />
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap');
    
    body {
      font-family: 'Outfit', sans-serif;
      margin: 0;
      display: flex;
      min-height: 100vh;
      background-color: #f8fafc;
      color: #1e293b;
    }

    /* Kiri - Hero Section */
    .hero-section {
      width: 50%;
      position: relative;
      display: flex;
      flex-direction: column;
      padding: 4rem;
      background-color: #004d34;
      overflow: hidden;
    }

    .hero-bg {
      position: absolute;
      inset: 0;
      background-image: url('/assets/images/rektorat-unand-1.jpg');
      background-size: cover;
      background-position: center;
      z-index: 1;
    }

    /* Gradasi Hijau di ujung-ujung gambar (Vignette Hijau) */
    .hero-vignette {
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at center, transparent 15%, rgba(0, 85, 50, 0.85) 100%);
      z-index: 2;
    }
    
    .hero-gradient {
      position: absolute;
      inset: 0;
      background: linear-gradient(to bottom, rgba(0, 50, 30, 0.7) 0%, transparent 30%, transparent 60%, rgba(0, 50, 30, 0.85) 100%);
      z-index: 3;
    }

    .hero-content-top, .hero-content-bottom {
      position: relative;
      z-index: 10;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 1.2rem;
    }
    .brand img {
      height: 4.5rem;
      width: auto;
      object-fit: contain;
      filter: drop-shadow(0 2px 6px rgba(0,0,0,0.3));
    }
    .brand span {
      color: #fff;
      font-size: 1.5rem;
      font-weight: 700;
      letter-spacing: 0.02em;
      text-shadow: 0 2px 4px rgba(0,0,0,0.4);
    }

    .hero-content-middle {
      position: relative;
      z-index: 10;
      margin-top: 0;
    }

    .hero-content-bottom {
      position: relative;
      z-index: 10;
      margin-top: auto;
      margin-bottom: 1.5rem;
    }

    .hero-text h1 {
      color: #fff;
      font-size: 3.2rem;
      line-height: 1.1;
      font-weight: 700;
      margin-bottom: 1rem;
      text-shadow: 0 2px 8px rgba(0,0,0,0.3);
      letter-spacing: -0.02em;
    }
    .hero-text p {
      color: rgba(255, 255, 255, 0.95);
      font-size: 1.1rem;
      line-height: 1.6;
      max-width: 480px;
      text-shadow: 0 1px 4px rgba(0,0,0,0.3);
    }

    .hero-footer {
      color: rgba(255, 255, 255, 0.7);
      font-size: 0.85rem;
      position: relative;
      z-index: 10;
      border-top: 1px solid rgba(255,255,255,0.2);
      padding-top: 1.5rem;
    }

    /* Kanan - Form Section */
    .form-section {
      width: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem;
      background-color: #f8fafc;
    }

    .login-card {
      width: 100%;
      max-width: 460px;
      background: #fff;
      padding: 3.5rem 3rem;
      border-radius: 24px;
      box-shadow: 0 25px 50px -12px rgba(0,0,0,0.08), 0 10px 15px -3px rgba(0,0,0,0.03);
      border: 1px solid rgba(0,0,0,0.04);
    }

    /* Bagian yang dibagusin: "Selamat datang kembali" */
    .login-header {
      margin-bottom: 2.5rem;
      position: relative;
    }
    
    .login-header::before {
      content: "";
      position: absolute;
      top: -16px;
      left: 0;
      width: 45px;
      height: 5px;
      background: #008556;
      border-radius: 4px;
    }

    .login-title {
      font-size: 2.1rem;
      font-weight: 700;
      color: #0f172a;
      margin: 0 0 0.5rem 0;
      letter-spacing: -0.02em;
    }

    .login-subtitle {
      font-size: 1rem;
      color: #64748b;
      margin: 0;
    }

    /* Input Fields */
    .form-group {
      margin-bottom: 1.5rem;
    }

    .form-label {
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 0.9rem;
      font-weight: 600;
      color: #334155;
      margin-bottom: 0.6rem;
    }

    .forgot-link {
      color: #008556;
      font-weight: 500;
      text-decoration: none;
      font-size: 0.85rem;
      transition: color 0.2s;
    }

    .forgot-link:hover {
      color: #036b46;
      text-decoration: underline;
    }

    .input-wrapper {
      position: relative;
    }

    .input-icon {
      position: absolute;
      left: 1.2rem;
      top: 50%;
      transform: translateY(-50%);
      color: #94a3b8;
      transition: color 0.2s;
    }

    .form-input {
      width: 100%;
      height: 54px;
      padding: 0 1.2rem 0 3.2rem;
      font-size: 1rem;
      font-family: inherit;
      color: #0f172a;
      background: #f8fafc;
      border: 1.5px solid #e2e8f0;
      border-radius: 14px;
      transition: all 0.2s;
      box-sizing: border-box;
    }

    .form-input:focus {
      outline: none;
      background: #fff;
      border-color: #008556;
      box-shadow: 0 0 0 4px rgba(0, 133, 86, 0.12);
    }
    
    /* Hover state untuk input */
    .form-input:not(:focus):hover {
      border-color: #cbd5e1;
    }

    /* Interaksi Icon */
    .form-input:focus + .input-icon {
      color: #008556;
    }

    .toggle-password {
      position: absolute;
      right: 1.2rem;
      top: 50%;
      transform: translateY(-50%);
      background: none;
      border: none;
      color: #94a3b8;
      cursor: pointer;
      padding: 0;
      transition: color 0.2s;
    }
    
    .toggle-password:hover {
      color: #475569;
    }

    .btn-submit {
      width: 100%;
      height: 54px;
      background: #008556;
      color: #fff;
      font-size: 1.05rem;
      font-weight: 600;
      font-family: inherit;
      border: none;
      border-radius: 14px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.6rem;
      transition: all 0.2s;
      margin-top: 2rem;
      box-shadow: 0 4px 12px rgba(0, 133, 86, 0.2);
    }

    .btn-submit:hover {
      background: #006c45;
      transform: translateY(-2px);
      box-shadow: 0 8px 20px rgba(0, 133, 86, 0.25);
    }
    
    .btn-submit:active {
      transform: translateY(0);
    }

    .error-alert {
      background: #fef2f2;
      color: #b91c1c;
      padding: 1rem 1.2rem;
      border-radius: 12px;
      font-size: 0.9rem;
      font-weight: 500;
      margin-bottom: 1.5rem;
      display: flex;
      align-items: center;
      gap: 0.6rem;
      border: 1px solid #fecaca;
    }

    .register-text {
      text-align: center;
      margin-top: 2.5rem;
      font-size: 0.9rem;
      color: #64748b;
    }
    
    .register-text a {
      color: #008556;
      font-weight: 600;
      text-decoration: none;
    }

    /* Responsivitas untuk layar kecil */
    @media (max-width: 900px) {
      .hero-section { display: none; }
      .form-section { width: 100%; padding: 1.5rem; background: #fff; }
      .login-card { 
        padding: 2rem; 
        box-shadow: none;
        border: none;
        max-width: 100%;
      }
    }
  </style>
</head>
<body>

  <!-- Bagian Kiri (Gambar & Informasi) -->
  <div class="hero-section">
    <div class="hero-bg"></div>
    <!-- Gradasi Vignette (Hanya Hijau di bagian ujung) -->
    <div class="hero-vignette"></div>
    <div class="hero-gradient"></div>

    <div class="hero-content-top">
      <div class="brand">
        <img src="/assets/images/logo-unand.png" alt="Logo UNAND" />
        <span>Universitas Andalas</span>
      </div>
    </div>

    <div class="hero-content-middle hero-text">
      <h1>Sistem Pengabdian<br>Masyarakat</h1>
    </div>

    <div class="hero-content-bottom hero-text">
      <p>Platform terintegrasi pengelolaan data pengabdian dosen secara transparan, akuntabel, dan berdampak nyata bagi masyarakat.</p>
    </div>
    
    <div class="hero-footer">
      © 2026 Universitas Andalas. Hak Cipta Dilindungi Undang-Undang.
    </div>
  </div>

  <!-- Bagian Kanan (Form Login) -->
  <div class="form-section">
    <div class="login-card">
      
      <!-- Bagian yang "dibagusin" -->
      <div class="login-header">
        <h2 class="login-title">Selamat Datang Kembali</h2>
        <p class="login-subtitle">Silakan masuk ke akun Anda untuk melanjutkan.</p>
      </div>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="error-alert">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <%= error %>
        </div>
      <% } %>

      <form action="/login" method="POST">
        
        <div class="form-group">
          <div class="form-label">Nama Pengguna</div>
          <div class="input-wrapper">
            <input type="text" name="username" class="form-input" placeholder="Masukkan username" required autocomplete="off" />
            <svg class="input-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
          </div>
        </div>

        <div class="form-group">
          <div class="form-label">
            Kata Sandi
            <a href="#" class="forgot-link">Lupa Sandi?</a>
          </div>
          <div class="input-wrapper">
            <input type="password" id="password" name="password" class="form-input" placeholder="••••••••" required />
            <svg class="input-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8V7a4 4 0 00-8 0v4h8z" />
            </svg>
            <button type="button" class="toggle-password" onclick="togglePass()">
              <svg id="eye" xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
              </svg>
            </button>
          </div>
        </div>

        <button type="submit" class="btn-submit">
          Masuk ke Dashboard
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </button>

      </form>

      <div class="register-text">
        Belum memiliki akun? <a href="#">Hubungi Administrator</a>
      </div>

    </div>
  </div>

  <script>
    // Sedikit script interaksi untuk input icon color (agar sesuai dengan css input-icon yg sudah diatur pakai CSS sibling)
    // Sebenarnya CSS: .form-input:focus + .input-icon sudah bekerja.
    // Ini cuma fungsi show/hide password
    function togglePass() {
      const input = document.getElementById('password');
      if(input.type === 'password') {
        input.type = 'text';
      } else {
        input.type = 'password';
      }
    }
  </script>
</body>
</html>
