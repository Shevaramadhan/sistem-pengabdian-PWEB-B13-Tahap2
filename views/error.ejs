<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Error</title>
  <style>
    body { font-family: sans-serif; display: flex; align-items: center; justify-content: center; min-height: 100vh; margin: 0; background: #f9fafb; }
    .box { background: #fff; border: 1px solid #e5e7eb; border-radius: 12px; padding: 2rem 3rem; max-width: 600px; text-align: center; box-shadow: 0 4px 24px rgba(0,0,0,0.07); }
    h1 { color: #dc2626; font-size: 1.4rem; margin-bottom: 0.5rem; }
    p { color: #6b7280; margin-bottom: 1.5rem; }
    pre { background: #f3f4f6; padding: 1rem; border-radius: 8px; text-align: left; font-size: 0.8rem; color: #374151; overflow: auto; }
    a { display: inline-block; padding: 0.5rem 1.5rem; background: #16a34a; color: #fff; border-radius: 8px; text-decoration: none; font-size: 0.9rem; }
    a:hover { background: #15803d; }
  </style>
</head>
<body>
  <div class="box">
    <h1><%= typeof message !== 'undefined' ? message : (typeof error !== 'undefined' ? (error.message || 'Terjadi kesalahan') : 'Terjadi kesalahan') %></h1>
    <% if (typeof error !== 'undefined' && error && error.status) { %>
      <p>Status: <%= error.status %></p>
    <% } %>
    <% if (typeof error !== 'undefined' && error && error.stack && process && process.env && process.env.NODE_ENV !== 'production') { %>
      <pre><%= error.stack %></pre>
    <% } %>
    <a href="javascript:history.back()">← Kembali</a>
  </div>
</body>
</html>
