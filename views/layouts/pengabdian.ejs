<!doctype html>
<html lang="id">
<head>
  <script>
    (() => {
      try {
        const stored = localStorage.getItem("themeMode");
        if (stored ? stored === "dark" : matchMedia("(prefers-color-scheme: dark)").matches)
          document.documentElement.classList.add("dark");
      } catch (_) {}
      document.addEventListener("basecoat:theme", (e) => {
        const mode = e.detail?.mode;
        const dark = mode === "dark" ? true : mode === "light" ? false : !document.documentElement.classList.contains("dark");
        document.documentElement.classList.toggle("dark", dark);
        try { localStorage.setItem("themeMode", dark ? "dark" : "light"); } catch (_) {}
      });
    })();
    (function () {
      try { const t = localStorage.getItem("themeVariant"); if (t) document.documentElement.classList.add(`theme-${t}`); } catch (_) {}
    })();
  </script>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title><%= pageTitle %> — Sistem Pengabdian UNAND</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/assets/styles.css"/>
  <script src="https://unpkg.com/htmx.org@2.0.4/dist/htmx.min.js" defer></script>
  <style>
    :root {
      --ug: #008556; --ug-l: #006c45; --ug-p: #e8f5ed;
      --ugold: #C8A951; --ugold-p: #fdf8ec;
      --uborder: #e4eae7;
      --page-bg: #f5fbf7;
    }
    .dark {
      --ug: #04b073; --ug-l: #02945f; --ug-p: #062618;
      --uborder: #1a3024;
      --page-bg: #09120d;
    }
    
    body { 
      font-family: 'Plus Jakarta Sans', sans-serif; 
      background-color: var(--page-bg);
      color: #1e293b;
    }
    .dark body { color: #e2e8f0; }

    /* Page card - Modern Floating Style */
    .page-card {
      background: #ffffff; 
      border: 1px solid rgba(0, 133, 86, 0.08);
      border-radius: 20px; 
      overflow: hidden;
      box-shadow: 0 10px 30px rgba(0, 133, 86, 0.04), 0 1px 3px rgba(0, 0, 0, 0.02);
      transition: all 0.3s ease;
    }
    .dark .page-card { 
      background: #0f1c15; 
      border-color: var(--uborder); 
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2); 
    }
    
    .page-card-header {
      padding: 24px 28px; 
      border-bottom: 1px solid var(--uborder);
      display: flex; align-items: center; justify-content: space-between;
      background: rgba(255, 255, 255, 0.5);
    }
    .dark .page-card-header { background: transparent; border-color: var(--uborder); }
    
    .page-card-header h2 { font-size: 1.15rem; font-weight: 700; color: var(--ug); margin: 0; letter-spacing: -0.01em; }
    .page-card-header p  { font-size: 0.85rem; color: #64748b; margin: 4px 0 0; }
    .dark .page-card-header p { color: #94a3b8; }
    
    .page-card-body { padding: 28px; }
    
    .page-card-footer { 
      padding: 16px 28px; 
      border-top: 1px solid var(--uborder); 
      background: #fafdfb; 
    }
    .dark .page-card-footer { background: #0c1611; }

    /* Breadcrumb */
    .breadcrumb { display: flex; align-items: center; gap: 8px; font-size: 0.85rem; color: #94a3b8; margin-bottom: 24px; font-weight: 500; }
    .breadcrumb a { color: var(--ug); text-decoration: none; transition: color 0.2s; }
    .breadcrumb a:hover { color: var(--ug-l); text-decoration: underline; }
    .breadcrumb span { color: #cbd5e1; }

    /* Table - Clean & Elegant */
    .data-table { width: 100%; border-collapse: separate; border-spacing: 0; }
    .data-table thead th {
      background: var(--ug-p); color: #00603e; font-size: 0.75rem;
      font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em;
      padding: 14px 18px; text-align: left; 
    }
    .data-table thead th:first-child { border-top-left-radius: 12px; border-bottom-left-radius: 12px; }
    .data-table thead th:last-child { border-top-right-radius: 12px; border-bottom-right-radius: 12px; }
    
    .dark .data-table thead th { background: #0b2618; color: #4ade80; }
    
    .data-table tbody td { 
      padding: 16px 18px; font-size: 0.9rem; 
      border-bottom: 1px solid var(--uborder); color: #334155; 
      transition: background 0.2s;
    }
    .dark .data-table tbody td { color: #cbd5e1; }
    .data-table tbody tr:last-child td { border-bottom: none; }
    .data-table tbody tr:hover td { background: #f4faf7; }
    .dark .data-table tbody tr:hover td { background: #0b1a13; }

    /* Badge status */
    .badge { border-radius: 8px; padding: 4px 12px; font-size: 0.75rem; font-weight: 600; display: inline-flex; align-items: center; justify-content: center; letter-spacing: 0.02em; }
    .b-proposed  { background: #fffbeb; color: #b45309; border: 1px solid #fde68a; }
    .b-ongoing   { background: #ecfdf5; color: #047857; border: 1px solid #a7f3d0; }
    .b-completed { background: #eff6ff; color: #1d4ed8; border: 1px solid #bfdbfe; }
    .dark .b-proposed  { background: #2a1f06; color: #fbbf24; border-color: #553e08; }
    .dark .b-ongoing   { background: #062618; color: #34d399; border-color: #0b4b2e; }
    .dark .b-completed { background: #0f172a; color: #60a5fa; border-color: #1e3a8a; }

    /* Buttons */
    .btn-primary {
      display: inline-flex; align-items: center; gap: 8px;
      background: linear-gradient(135deg, var(--ug) 0%, var(--ug-l) 100%); 
      color: #fff; padding: 10px 20px;
      border-radius: 12px; font-size: 0.875rem; font-weight: 600;
      text-decoration: none; border: none; cursor: pointer;
      transition: all 0.3s ease;
      box-shadow: 0 4px 12px rgba(0, 133, 86, 0.2);
    }
    .btn-primary:hover { 
      transform: translateY(-2px);
      box-shadow: 0 8px 16px rgba(0, 133, 86, 0.3);
      background: linear-gradient(135deg, var(--ug-l) 0%, #005637 100%);
    }
    .btn-danger {
      display: inline-flex; align-items: center; gap: 8px;
      background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%); 
      color: #fff; padding: 9px 18px;
      border-radius: 12px; font-size: 0.85rem; font-weight: 600;
      border: none; cursor: pointer; transition: all 0.3s ease;
      box-shadow: 0 4px 12px rgba(220, 38, 38, 0.2);
    }
    .btn-danger:hover { 
      transform: translateY(-2px);
      box-shadow: 0 8px 16px rgba(220, 38, 38, 0.3);
    }
    .btn-ghost-sm {
      display: inline-flex; align-items: center; gap: 6px;
      color: var(--ug); font-size: 0.85rem; font-weight: 600;
      padding: 8px 14px; border-radius: 10px; text-decoration: none;
      border: 1px solid var(--uborder); background: #fff;
      transition: all 0.2s ease;
    }
    .btn-ghost-sm:hover { 
      border-color: var(--ug); background: var(--ug-p); 
      transform: translateY(-1px); box-shadow: 0 2px 8px rgba(0, 133, 86, 0.05);
    }
    .dark .btn-ghost-sm { background: #0f1c15; border-color: var(--uborder); color: var(--ug); }
    .dark .btn-ghost-sm:hover { border-color: var(--ug); background: #0b1a13; }

    /* Alert flash */
    .flash-success {
      background: #ecfdf5; border: 1px solid #a7f3d0; border-left: 5px solid #10b981;
      border-radius: 12px; padding: 14px 20px; margin-bottom: 20px;
      font-size: 0.9rem; font-weight: 500; color: #065f46; display: flex; align-items: center; gap: 12px;
      box-shadow: 0 4px 12px rgba(16, 185, 129, 0.05);
    }
    .flash-error {
      background: #fef2f2; border: 1px solid #fecaca; border-left: 5px solid #ef4444;
      border-radius: 12px; padding: 14px 20px; margin-bottom: 20px;
      font-size: 0.9rem; font-weight: 500; color: #991b1b;
      box-shadow: 0 4px 12px rgba(239, 68, 68, 0.05);
    }
    .flash-error li { margin: 4px 0 4px 20px; list-style: disc; }

    /* Form */
    .form-group { margin-bottom: 22px; }
    .form-label { display: block; font-size: 0.875rem; font-weight: 600; color: #1e293b; margin-bottom: 8px; }
    .dark .form-label { color: #e2e8f0; }
    .form-input {
      width: 100%; padding: 12px 16px; border: 1px solid #cbd5e1;
      border-radius: 12px; font-size: 0.95rem; color: #0f172a; font-family: inherit;
      background: #fff; transition: all 0.2s ease;
      outline: none; box-sizing: border-box;
    }
    .form-input:hover { border-color: #94a3b8; }
    .form-input:focus { border-color: var(--ug); box-shadow: 0 0 0 4px rgba(0, 133, 86, 0.1); }
    .dark .form-input { background: #0b140f; border-color: var(--uborder); color: #f8fafc; }
    .dark .form-input:focus { border-color: var(--ug); box-shadow: 0 0 0 4px rgba(4, 176, 115, 0.15); }
    .form-input[required] + .form-hint::before { content: "* "; color: #ef4444; }
    .form-hint { font-size: 0.8rem; color: #64748b; margin-top: 6px; }
    .form-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    @media (max-width: 640px) { .form-grid-2 { grid-template-columns: 1fr; } }

    /* Pagination */
    .pagination { display: flex; align-items: center; gap: 8px; }
    .pg-btn {
      padding: 8px 14px; border-radius: 10px; border: 1px solid #cbd5e1;
      font-size: 0.875rem; font-weight: 600; text-decoration: none; color: #475569; background: #fff;
      transition: all 0.2s ease;
    }
    .dark .pg-btn { background: #0f1c15; border-color: var(--uborder); color: #cbd5e1; }
    .pg-btn:hover { border-color: var(--ug); background: var(--ug-p); color: var(--ug); transform: translateY(-1px); }
    .pg-btn.active { background: var(--ug); color: #fff; border-color: var(--ug); box-shadow: 0 4px 10px rgba(0, 133, 86, 0.2); }
    .pg-btn:disabled, .pg-btn[disabled] { opacity: 0.4; pointer-events: none; }

    /* Search bar */
    .search-bar { display: flex; gap: 10px; align-items: center; }
    .search-input {
      padding: 10px 16px 10px 42px; border: 1px solid #cbd5e1; border-radius: 12px;
      font-size: 0.9rem; color: #0f172a; background: #fff; outline: none; font-family: inherit;
      transition: all 0.2s ease; min-width: 250px;
    }
    .search-input:focus { border-color: var(--ug); box-shadow: 0 0 0 4px rgba(0, 133, 86, 0.1); }
    .dark .search-input { background: #0b140f; border-color: var(--uborder); color: #f8fafc; }
    .search-wrap { position: relative; }
    .search-wrap svg { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); pointer-events: none; color: #94a3b8; }

    /* Empty state */
    .empty-state { text-align: center; padding: 70px 24px; }
    .empty-icon {
      width: 72px; height: 72px; background: var(--ug-p); border-radius: 50%;
      display: flex; align-items: center; justify-content: center; margin: 0 auto 20px;
      color: var(--ug);
    }
    .empty-state h3 { font-size: 1.1rem; font-weight: 700; color: #1e293b; margin: 0 0 8px; letter-spacing: -0.01em; }
    .dark .empty-state h3 { color: #f8fafc; }
    .empty-state p  { font-size: 0.9rem; color: #64748b; margin: 0 0 24px; max-width: 400px; margin-inline: auto; line-height: 1.6; }
  </style>
</head>
<body>
  <%- include('../partials/sidebar') %>
  <main id="content">
    <%- include('../partials/topbar', { pageTitle }) %>
    <div style="padding: 20px 28px; max-width: 1200px; margin: 0 auto;">
      <%- body %>
    </div>
  </main>
  <script src="/assets/js/basecoat.js" defer></script>
  <script src="/assets/js/sidebar.js" defer></script>
  <script src="/assets/js/popover.js" defer></script>
  <script src="/assets/js/toast.js" defer></script>
  <script>
    document.addEventListener("DOMContentLoaded", function() {
      var sidebar = document.getElementById("sidebar");
      if (!sidebar) return;
      var currentPath = window.location.pathname.replace(/\/$/, "");
      sidebar.querySelectorAll("a").forEach(function(a) {
        var href = a.getAttribute("href");
        if (!href) return;
        try {
          var url = new URL(href, window.location.origin);
          if (url.pathname.replace(/\/$/, "") === currentPath) a.setAttribute("aria-current", "page");
        } catch(_) {}
      });
    });

    // Auto-dismiss flash
    setTimeout(() => {
      document.querySelectorAll('.flash-success').forEach(el => el.style.display = 'none');
    }, 5000);

    // Otomatis intercept form submit untuk AJAX dengan JSON respons
    document.addEventListener('submit', async (e) => {
      const form = e.target;
      // Jangan pakai AJAX untuk form pencarian (GET) atau form export
      const method = (form.getAttribute('method') || 'GET').toUpperCase();
      if (method === 'GET') return;
      
      e.preventDefault();
      
      const action = form.getAttribute('action') || window.location.href;
      let bodyData;
      
      if (form.enctype === 'multipart/form-data') {
        bodyData = new FormData(form);
      } else {
        bodyData = new URLSearchParams(new FormData(form));
      }

      try {
        const res = await fetch(action, {
          method: method,
          headers: { 'Accept': 'application/json' },
          body: bodyData
        });
        
        const result = await res.json();
        
        if (result.status === 'success') {
          if (result.redirectUrl) {
            window.location.href = result.redirectUrl;
          } else {
            window.location.reload();
          }
        } else {
          alert('Error: ' + (result.message || 'Terjadi kesalahan pada server.'));
        }
      } catch (err) {
        console.error('Fetch error:', err);
        alert('Gagal menghubungi server. Pastikan server menyala.');
      }
    });
  </script>
  <%- typeof extraScript !== 'undefined' ? extraScript : '' %>
</body>
</html>
