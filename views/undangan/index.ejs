<div class="breadcrumb">
  <a href="/undangan">Keanggotaan</a>
  <span>/</span>
  <span>Undangan</span>
</div>

<div class="page-card mb-6">
  <div class="page-card-header">
    <div>
      <h2>Daftar Undangan Keanggotaan</h2>
      <p>Kelola undangan untuk bergabung dalam tim pengabdian masyarakat.</p>
    </div>
  </div>
  
  <div class="page-card-body">

    <%# Flash Messages %>
    <% if (flash && flashType === 'success') { %>
      <div class="flash-success" style="margin-bottom:20px;">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        <span><%= flash %></span>
      </div>
    <% } %>
    <% if (flash && flashType === 'error') { %>
      <div class="flash-error" style="margin-bottom:20px;">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <span><%= flash %></span>
      </div>
    <% } %>

    <% if (invitations && invitations.length > 0) { %>
      <div style="overflow-x: auto;">
        <table class="data-table">
          <thead>
            <tr>
              <th>Pengabdian</th>
              <th>Dosen Pengusul</th>
              <th>Peran Anda</th>
              <th>Status</th>
              <th style="text-align: center;">Tanggal Undangan</th>
              <th style="text-align: center;">Aksi</th>
            </tr>
          </thead>
          <tbody>
            <% invitations.forEach(inv => { %>
              <tr>
                <td>
                  <div style="font-weight: 600; color: #1e293b;"><%= inv.service_title %></div>
                  <div style="font-size: 0.8rem; color: #64748b; margin-top: 3px;">
                    <%= inv.location %> &bull; <%= new Date(inv.start_date).toLocaleDateString('id-ID') %>
                  </div>
                </td>
                <td style="font-weight: 500;"><%= inv.creator_name %></td>
                <td>
                  <span style="background: #f1f5f9; color: #475569; padding: 3px 10px; border-radius: 6px; font-size: 0.8rem; font-weight: 600;">
                    <%= inv.member_role %>
                  </span>
                </td>
                <td>
                  <% if (inv.status === 'pending') { %>
                    <span class="badge b-proposed">⏳ Menunggu</span>
                  <% } else if (inv.status === 'approved') { %>
                    <span class="badge b-ongoing">✓ Disetujui</span>
                  <% } else if (inv.status === 'rejected') { %>
                    <span class="badge" style="background:#fef2f2; color:#dc2626; border:1px solid #fecaca; border-radius:8px; padding: 4px 12px; font-size:0.75rem; font-weight:600;">✕ Ditolak</span>
                  <% } %>
                </td>
                <td style="text-align: center; color: #64748b; font-size: 0.85rem;">
                  <%= new Date(inv.created_at).toLocaleDateString('id-ID', {day:'2-digit', month:'short', year:'numeric'}) %>
                </td>
                <td style="text-align: center;">
                  <% if (inv.status === 'pending') { %>
                    <div style="display: flex; gap: 6px; justify-content: center; align-items: center;">
                      <%# Tombol Terima %>
                      <form method="POST" action="/undangan/<%= inv.id %>/approve" style="margin:0;" onsubmit="return confirm('Yakin ingin MENERIMA undangan ini?')">
                        <button type="submit" style="display:inline-flex; align-items:center; gap:5px; padding:7px 14px; border-radius:10px; border:none; cursor:pointer; font-size:0.8rem; font-weight:600; font-family:inherit; background: linear-gradient(135deg, #008556, #006440); color:#fff; box-shadow: 0 3px 8px rgba(0,133,86,0.25); transition: all 0.2s;"
                          onmouseover="this.style.transform='translateY(-1px)'" onmouseout="this.style.transform='translateY(0)'">
                          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                          Terima
                        </button>
                      </form>
                      <%# Tombol Tolak %>
                      <form method="POST" action="/undangan/<%= inv.id %>/reject" style="margin:0;" onsubmit="return confirm('Yakin ingin MENOLAK undangan ini?')">
                        <button type="submit" style="display:inline-flex; align-items:center; gap:5px; padding:7px 14px; border-radius:10px; border:none; cursor:pointer; font-size:0.8rem; font-weight:600; font-family:inherit; background: linear-gradient(135deg, #ef4444, #dc2626); color:#fff; box-shadow: 0 3px 8px rgba(220,38,38,0.25); transition: all 0.2s;"
                          onmouseover="this.style.transform='translateY(-1px)'" onmouseout="this.style.transform='translateY(0)'">
                          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                          Tolak
                        </button>
                      </form>
                    </div>
                  <% } else { %>
                    <%# Tombol Unduh Bukti PDF %>
                    <a href="/undangan/<%= inv.id %>/bukti" 
                       style="display:inline-flex; align-items:center; gap:6px; padding:7px 14px; border-radius:10px; font-size:0.8rem; font-weight:600; text-decoration:none; border: 1.5px solid #e2e8f0; background: #f8fafc; color: #475569; transition: all 0.2s;"
                       onmouseover="this.style.borderColor='#008556'; this.style.color='#008556'; this.style.background='#e8f5ed'"
                       onmouseout="this.style.borderColor='#e2e8f0'; this.style.color='#475569'; this.style.background='#f8fafc'">
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                      Unduh Bukti
                    </a>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="empty-state">
        <div class="empty-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="var(--ug, #008556)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 17a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V9.5C2 7 4 5 6.5 5H18c2.2 0 4 1.8 4 4v8Z"/></svg>
        </div>
        <h3>Belum Ada Undangan</h3>
        <p>Saat ini Anda belum menerima undangan untuk bergabung ke tim pengabdian mana pun.</p>
      </div>
    <% } %>

  </div>
</div>
