<!doctype html>
<html lang="id">
<head>
  <script>
    (() => {
      try {
        const stored = localStorage.getItem("themeMode");
        if (stored ? stored === "dark" : matchMedia("(prefers-color-scheme: dark)").matches)
          document.documentElement.classList.add("dark");
      } catch (_) {}
      document.addEventListener("basecoat:theme", (e) => {
        const mode = e.detail?.mode;
        const dark = mode === "dark" ? true : mode === "light" ? false : !document.documentElement.classList.contains("dark");
        document.documentElement.classList.toggle("dark", dark);
        try { localStorage.setItem("themeMode", dark ? "dark" : "light"); } catch (_) {}
      });
    })();
    (function () {
      try {
        const t = localStorage.getItem("themeVariant");
        if (t) document.documentElement.classList.add(`theme-${t}`);
      } catch (_) {}
    })();
  </script>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>Undangan Keanggotaan — Sistem Pengabdian UNAND</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/assets/styles.css"/>
  <script src="https://unpkg.com/htmx.org@2.0.4/dist/htmx.min.js" defer></script>
  <style>
    :root {
      --unand-green:       #006B35;
      --unand-green-light: #1a8a4a;
      --unand-green-pale:  #e8f5ed;
      --unand-gold:        #C8A951;
      --unand-gold-dark:   #96782e;
      --unand-gold-pale:   #fdf8ec;
    }
    body { font-family: 'Inter', sans-serif; }

    /* ── Card ── */
    .unand-card {
      background: #fff;
      border: 1px solid #e8edf0;
      border-radius: 14px;
      overflow: hidden;
      box-shadow: 0 1px 4px rgba(0,0,0,0.05);
      margin-bottom: 24px;
    }
    .dark .unand-card { background: #1e2a24; border-color: #2d3f35; }
    .unand-card-header {
      padding: 20px 24px 16px;
      border-bottom: 1px solid #f0f4f2;
    }
    .dark .unand-card-header { border-color: #2d3f35; }
    .unand-card-header h2 { font-size: 1rem; font-weight: 600; color: var(--unand-green); margin: 0; }
    .dark .unand-card-header h2 { color: #86c99e; }
    .unand-card-header p { font-size: 0.8rem; color: #6b7280; margin: 4px 0 0; }
    .dark .unand-card-header p { color: #9ca3af; }

    /* ── Table custom ── */
    .data-table { width: 100%; border-collapse: separate; border-spacing: 0; }
    .data-table thead th {
      background: var(--unand-green-pale);
      color: var(--unand-green);
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      padding: 12px 16px;
      border-bottom: 2px solid #d1e8d9;
    }
    .dark .data-table thead th { background: #1e2a24; color: #86c99e; border-color: #2d3f35; }
    .data-table tbody td { padding: 14px 16px; border-bottom: 1px solid #f0f4f2; font-size: 0.875rem; vertical-align: middle; }
    .dark .data-table tbody td { border-color: #2d3f35; color: #d1e0d8; }
    .data-table tbody tr:hover td { background: var(--unand-green-pale); }
    .dark .data-table tbody tr:hover td { background: rgba(30,42,36,0.6); }

    .badge-member-pending { background: #fef3c7; color: #d97706; border: 1px solid #fcd34d; border-radius: 999px; padding: 2px 10px; font-size: 0.72rem; font-weight: 500; display: inline-flex; align-items: center; }
    .badge-member-approved { background: #d1fae5; color: #059669; border: 1px solid #6ee7b7; border-radius: 999px; padding: 2px 10px; font-size: 0.72rem; font-weight: 500; display: inline-flex; align-items: center; }
    .badge-member-rejected { background: #fee2e2; color: #dc2626; border: 1px solid #fca5a5; border-radius: 999px; padding: 2px 10px; font-size: 0.72rem; font-weight: 500; display: inline-flex; align-items: center; }
    
    .dark .badge-member-pending { background: #271a0c; color: #fbbf24; border-color: #78350f; }
    .dark .badge-member-approved { background: #062419; color: #34d399; border-color: #064e3b; }
    .dark .badge-member-rejected { background: #2a0c0c; color: #f87171; border-color: #7f1d1d; }

    .btn-action-accept { background: var(--unand-green); color:#fff; padding:6px 12px; border-radius:8px; font-size:0.78rem; font-weight:600; text-decoration:none; display:inline-flex; align-items:center; gap:4px; transition:background 0.2s; }
    .btn-action-accept:hover { background: var(--unand-green-light); }
    .btn-action-reject { background:#fff; color:#dc2626; border:1px solid #fca5a5; padding:5px 12px; border-radius:8px; font-size:0.78rem; font-weight:600; text-decoration:none; display:inline-flex; align-items:center; gap:4px; transition:all 0.2s; }
    .btn-action-reject:hover { background:#fee2e2; }
    .dark .btn-action-reject { background:#1e2a24; color:#f87171; border-color:#7f1d1d; }
    .dark .btn-action-reject:hover { background:#2d1010; }
  </style>
</head>
<body>

  <%- include('../partials/sidebar') %>

  <main id="content">
    <%- include('../partials/topbar', { pageTitle: 'Undangan Keanggotaan' }) %>

    <div class="p-4 md:p-6" style="max-width:1280px; margin:0 auto;">
      
      <div class="unand-card">
        <div class="unand-card-header">
          <h2>Undangan Keanggotaan Tim Pengabdian</h2>
          <p>Daftar usulan kegiatan pengabdian yang mengundang Anda sebagai anggota tim.</p>
        </div>

        <% if (invitations.length === 0) { %>
        <!-- Empty State -->
        <div style="text-align:center; padding:64px 24px;">
          <div style="width:72px; height:72px; background:var(--unand-green-pale); border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 20px;">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--unand-green)" stroke-width="1.5">
              <path d="M22 17a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V9.5C2 7 4 5 6.5 5H18c2.2 0 4 1.8 4 4v8Z"/>
            </svg>
          </div>
          <h3 style="font-size:1.1rem; font-weight:600; margin:0 0 6px;" class="dark:text-zinc-200">Tidak Ada Undangan</h3>
          <p style="font-size:0.85rem; color:#9ca3af; margin:0; max-width:320px; margin-left:auto; margin-right:auto;">
            Saat ini Anda tidak memiliki undangan masuk untuk bergabung sebagai anggota tim pengabdian dosen.
          </p>
        </div>
        <% } else { %>
        <div style="overflow-x:auto;">
          <table class="data-table">
            <thead>
              <tr>
                <th style="width:40px; text-align:center;">#</th>
                <th style="text-align:left;">Judul Pengabdian</th>
                <th style="text-align:left;">Ketua Pengusul</th>
                <th style="text-align:left;">Lokasi & Tanggal</th>
                <th style="text-align:center; width:120px;">Status Anda</th>
                <th style="text-align:center; width:220px;">Aksi Respon</th>
              </tr>
            </thead>
            <tbody>
              <% invitations.forEach(function(inv, idx) { %>
              <tr>
                <td style="text-align:center; color:#9ca3af;"><%= idx + 1 %></td>
                <td>
                  <a href="/pengabdian/<%= inv.cs_id %>" style="font-weight:600; color:#111827; text-decoration:none; line-height:1.4;" class="dark:text-white hover:underline">
                    <%= inv.cs_title %>
                  </a>
                </td>
                <td>
                  <span style="font-weight:500;"><%= inv.creator_name %></span>
                </td>
                <td style="color:#6b7280;" class="dark:text-zinc-300">
                  <div style="font-size:0.82rem;">Mitra: <%= inv.cs_location %></div>
                  <div style="font-size:0.75rem; color:#9ca3af; margin-top:2px;">
                    Mulai: <%= new Date(inv.cs_start_date).toLocaleDateString('id-ID', {day:'numeric',month:'short',year:'numeric'}) %>
                  </div>
                </td>
                <td style="text-align:center;">
                  <% if (inv.status === 'pending') { %>
                    <span class="badge-member-pending">Pending</span>
                  <% } else if (inv.status === 'approved') { %>
                    <span class="badge-member-approved">Disetujui</span>
                  <% } else { %>
                    <span class="badge-member-rejected">Ditolak</span>
                  <% } %>
                </td>
                <td style="text-align:center;">
                  <% if (inv.status === 'pending') { %>
                    <div style="display:inline-flex; gap:8px;">
                      <a href="/undangan/<%= inv.member_record_id %>/accept" class="btn-action-accept">
                        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                        Terima
                      </a>
                      <a href="/undangan/<%= inv.member_record_id %>/reject" class="btn-action-reject">
                        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                        Tolak
                      </a>
                    </div>
                  <% } else { %>
                    <span style="font-size:0.8rem; color:#9ca3af;" class="dark:text-zinc-500">
                      Direspons pada <%= inv.status === 'approved' ? 'Setuju' : 'Tolak' %>
                    </span>
                  <% } %>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <% } %>
      </div>

    </div>
  </main>

  <script src="/assets/js/basecoat.js" defer></script>
  <script src="/assets/js/sidebar.js" defer></script>
  <script src="/assets/js/dropdown-menu.js" defer></script>
  <script src="/assets/js/popover.js" defer></script>
  <script src="/assets/js/toast.js" defer></script>
</body>
</html>
