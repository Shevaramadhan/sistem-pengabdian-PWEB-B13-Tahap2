<div class="breadcrumb">
  <a href="/pengabdian">Daftar Pengabdian</a>
  <span>/</span>
  <span>Detail</span>
</div>

<!-- Flash Messages -->
<% if (typeof req !== 'undefined' && req.query) { %>
  <% if (req.query.success === 'updated') { %>
    <div class="flash-success mb-4"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg><span>Data pengabdian berhasil diperbarui.</span></div>
  <% } else if (req.query.success === 'laporan_uploaded') { %>
    <div class="flash-success mb-4"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg><span>Laporan hasil pengabdian berhasil diupload.</span></div>
  <% } else if (req.query.success === 'finalized') { %>
    <div class="flash-success mb-4"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg><span>Pengabdian berhasil difinalisasi. Status berubah menjadi <strong>Selesai</strong>.</span></div>
  <% } else if (req.query.error === 'no_report') { %>
    <div class="flash-error mb-4">Finalisasi gagal: <strong>Upload laporan hasil terlebih dahulu</strong> sebelum memfinalisasi pengabdian.</div>
  <% } else if (req.query.error === 'already_finalized') { %>
    <div class="flash-error mb-4">Pengabdian ini sudah difinalisasi sebelumnya.</div>
  <% } %>
<% } %>

<div class="page-card mb-6">
  <div class="page-card-header">
    <div>
      <h2><%= service.title %></h2>
      <p>Detail kegiatan pengabdian &bull;
        <% if (service.is_finalized) { %>
          <span style="color: #1e40af; font-weight: 600;">🔒 Sudah Difinalisasi</span>
        <% } else { %>
          <span style="color: #92650a;">Belum difinalisasi</span>
        <% } %>
      </p>
    </div>
    <% if (!service.is_finalized && (isAdmin || service.created_by === locals.user?.id)) { %>
      <div style="display: flex; gap: 8px; flex-wrap: wrap;">
        <a href="/pengabdian/<%= service.id %>/edit" class="btn-ghost-sm">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/></svg>
          Edit
        </a>
        <a href="/pengabdian/<%= service.id %>/upload" class="btn-ghost-sm" style="color: #0369a1; border-color: #bae6fd;">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" x2="12" y1="3" y2="15"/></svg>
          Upload Laporan
        </a>
        <% if (service.report_file) { %>
          <form action="/pengabdian/<%= service.id %>/finalisasi" method="POST" style="display: inline;" onsubmit="return confirm('Setelah difinalisasi, data tidak bisa diubah lagi. Lanjutkan?');">
            <button type="submit" class="btn-primary" style="padding: 6px 14px; font-size: 0.78rem;">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
              Finalisasi
            </button>
          </form>
        <% } %>
      </div>
    <% } %>
  </div>
  
  <div class="page-card-body">
    <div class="form-grid-2">
      <div>
        <h4 class="text-sm font-semibold text-muted-foreground mb-1">Status</h4>
        <div class="mb-4">
          <% if (service.status === 'proposed') { %>
            <span class="badge b-proposed">Diusulkan</span>
          <% } else if (service.status === 'ongoing') { %>
            <span class="badge b-ongoing">Berjalan</span>
          <% } else { %>
            <span class="badge b-completed">Selesai</span>
          <% } %>
          <% if (service.is_finalized) { %>
            <span class="badge" style="background: #eff6ff; color: #1e40af; border: 1px solid #bfdbfe; margin-left: 6px;">🔒 Final</span>
          <% } %>
        </div>

        <h4 class="text-sm font-semibold text-muted-foreground mb-1">Dosen Pengusul</h4>
        <p class="mb-4 text-sm font-medium"><%= service.creator_name %></p>

        <h4 class="text-sm font-semibold text-muted-foreground mb-1">Lokasi</h4>
        <p class="mb-4 text-sm"><%= service.location %></p>
      </div>
      <div>
        <h4 class="text-sm font-semibold text-muted-foreground mb-1">Tanggal Mulai</h4>
        <p class="mb-4 text-sm"><%= new Date(service.start_date).toLocaleDateString('id-ID', {day: 'numeric', month: 'long', year: 'numeric'}) %></p>

        <h4 class="text-sm font-semibold text-muted-foreground mb-1">Tanggal Selesai</h4>
        <p class="mb-4 text-sm"><%= service.end_date ? new Date(service.end_date).toLocaleDateString('id-ID', {day: 'numeric', month: 'long', year: 'numeric'}) : '-' %></p>

        <h4 class="text-sm font-semibold text-muted-foreground mb-1">Sumber Pendanaan</h4>
        <p class="mb-4 text-sm"><%= service.funding_source || '-' %></p>
      </div>
    </div>

    <div class="mb-4">
      <h4 class="text-sm font-semibold text-muted-foreground mb-1">Deskripsi</h4>
      <p class="text-sm whitespace-pre-line bg-muted p-4 rounded-md border border-border" style="background: #f9fafb; border: 1px solid #e4eae7; border-radius: 8px; padding: 12px 16px;"><%= service.description || 'Tidak ada deskripsi.' %></p>
    </div>

    <!-- Laporan Hasil -->
    <div>
      <h4 class="text-sm font-semibold text-muted-foreground mb-2">Laporan Hasil Pengabdian</h4>
      <% if (service.report_file) { %>
        <div style="display: flex; align-items: center; gap: 12px; background: var(--ug-p); border: 1px solid #b5d9c4; border-radius: 8px; padding: 12px 16px;">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--ug)" stroke-width="1.5"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
          <div style="flex: 1; min-width: 0;">
            <div style="font-weight: 600; font-size: 0.85rem; color: var(--ug);">Laporan tersedia</div>
            <div style="font-size: 0.75rem; color: #4a7a5e; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"><%= service.report_file %></div>
          </div>
          <a href="/uploads/laporan/<%= service.report_file %>" target="_blank" class="btn-ghost-sm" style="white-space: nowrap;">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
            Download
          </a>
        </div>
      <% } else { %>
        <div style="border: 2px dashed #d1e8d9; border-radius: 8px; padding: 20px; text-align: center; color: #6b7280;">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="1.5" style="display: block; margin: 0 auto 8px;"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
          <p style="font-size: 0.82rem; margin: 0 0 10px;">Belum ada laporan yang diupload.</p>
          <% if (!service.is_finalized && (isAdmin || service.created_by === locals.user?.id)) { %>
            <a href="/pengabdian/<%= service.id %>/upload" class="btn-ghost-sm">Upload Sekarang</a>
          <% } %>
        </div>
      <% } %>
    </div>
  </div>
</div>

<div class="page-card">
  <div class="page-card-header">
    <div>
      <h2>Anggota Tim Pengabdian</h2>
      <p>Daftar dosen yang terlibat dalam pengabdian ini.</p>
    </div>
    <% if (!service.is_finalized && (isAdmin || service.created_by === locals.user?.id)) { %>
      <button class="btn-primary btn-sm" onclick="document.getElementById('addMemberModal').showModal()">
        + Tambah Anggota
      </button>
    <% } %>
  </div>
  
  <div class="page-card-body">
    <!-- Flash Messages for Members -->
    <% if (typeof req !== 'undefined' && req.query) { %>
      <% if (req.query.success === 'member_added') { %>
        <div class="flash-success"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg><span>Anggota berhasil ditambahkan.</span></div>
      <% } else if (req.query.success === 'member_updated') { %>
        <div class="flash-success"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg><span>Data anggota berhasil diupdate.</span></div>
      <% } else if (req.query.success === 'member_deleted') { %>
        <div class="flash-success"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg><span>Anggota berhasil dihapus.</span></div>
      <% } %>
    <% } %>

    <% if (members && members.length > 0) { %>
      <table class="data-table">
        <thead>
          <tr>
            <th>Nama Dosen</th>
            <th>Peran</th>
            <th>Keahlian</th>
            <th>Status Konfirmasi</th>
            <% if (!service.is_finalized && (isAdmin || service.created_by === locals.user?.id)) { %>
              <th style="text-align: center;">Aksi</th>
            <% } %>
          </tr>
        </thead>
        <tbody>
          <% members.forEach(member => { %>
            <tr>
              <td>
                <div style="font-weight: 500;"><%= member.lecturer_name %></div>
                <div style="font-size: 0.75rem; color: #6b7280;"><%= member.academic_rank %></div>
              </td>
              <td><%= member.member_role %></td>
              <td><%= member.expertise || '-' %></td>
              <td>
                <% if (member.status === 'pending') { %>
                  <span class="badge b-proposed">Menunggu</span>
                <% } else if (member.status === 'approved') { %>
                  <span class="badge b-ongoing">Disetujui</span>
                <% } else if (member.status === 'rejected') { %>
                  <span class="badge" style="background:#fef2f2; color:#dc2626; border:1px solid #fca5a5;">Ditolak</span>
                <% } %>
              </td>
              <% if (!service.is_finalized && (isAdmin || service.created_by === locals.user?.id)) { %>
                <td style="text-align: center; white-space: nowrap;">
                  <button class="btn-ghost-sm" onclick="openEditMemberModal('<%= member.id %>', '<%= member.member_role %>', '<%= member.status %>')">Edit</button>
                  <form action="/pengabdian/<%= service.id %>/anggota/<%= member.id %>/delete" method="POST" style="display: inline;" onsubmit="return confirm('Hapus anggota ini?');">
                    <button type="submit" class="btn-ghost-sm" style="color: #dc2626;">Hapus</button>
                  </form>
                </td>
              <% } %>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } else { %>
      <p style="text-align: center; color: #9ca3af; padding: 24px 0; font-size: 0.85rem;">Belum ada anggota tim.</p>
    <% } %>
  </div>
</div>

<!-- Add Member Modal -->
<dialog id="addMemberModal" style="border-radius: 12px; border: 1px solid #e4eae7; background: #fff; padding: 0; box-shadow: 0 8px 32px rgba(0,0,0,0.12); width: 100%; max-width: 400px;">
  <div style="padding: 24px;">
    <h3 style="font-size: 1rem; font-weight: 700; margin: 0 0 16px; color: var(--ug);">Tambah Anggota Tim</h3>
    <form action="/pengabdian/<%= service.id %>/anggota" method="POST">
      <div class="form-group">
        <label class="form-label">Dosen (Lecturer)</label>
        <select name="lecturer_id" class="form-input" required>
          <option value="">-- Pilih Dosen --</option>
          <% allLecturers.forEach(l => { %>
            <option value="<%= l.id %>"><%= l.name %> <%= l.academic_rank ? `(${l.academic_rank})` : '' %></option>
          <% }) %>
        </select>
        <div class="form-hint">Pilih dosen yang akan ditambahkan ke tim pengabdian ini.</div>
      </div>
      <div class="form-group">
        <label class="form-label">Peran dalam Tim</label>
        <input type="text" name="role" class="form-input" placeholder="Contoh: Anggota Peneliti" required>
      </div>
      <div style="display: flex; justify-content: flex-end; gap: 8p; margin-top: 20px;">
        <button type="button" class="btn-ghost-sm" onclick="document.getElementById('addMemberModal').close()">Batal</button>
        <button type="submit" class="btn-primary">Tambah</button>
      </div>
    </form>
  </div>
</dialog>

<!-- Edit Member Modal -->
<dialog id="editMemberModal" style="border-radius: 12px; border: 1px solid #e4eae7; background: #fff; padding: 0; box-shadow: 0 8px 32px rgba(0,0,0,0.12); width: 100%; max-width: 400px;">
  <div style="padding: 24px;">
    <h3 style="font-size: 1rem; font-weight: 700; margin: 0 0 16px; color: var(--ug);">Edit Anggota Tim</h3>
    <form id="editMemberForm" action="" method="POST">
      <div class="form-group">
        <label class="form-label">Peran dalam Tim</label>
        <input type="text" id="edit_role" name="role" class="form-input" required>
      </div>
      <div class="form-group">
        <label class="form-label">Status Konfirmasi</label>
        <select id="edit_status" name="status" class="form-input" required>
          <option value="pending">Menunggu</option>
          <option value="approved">Disetujui</option>
          <option value="rejected">Ditolak</option>
        </select>
      </div>
      <div style="display: flex; justify-content: flex-end; gap: 8px; margin-top: 20px;">
        <button type="button" class="btn-ghost-sm" onclick="document.getElementById('editMemberModal').close()">Batal</button>
        <button type="submit" class="btn-primary">Simpan</button>
      </div>
    </form>
  </div>
</dialog>

<script>
  function openEditMemberModal(memberId, role, status) {
    document.getElementById('edit_role').value = role;
    document.getElementById('edit_status').value = status;
    document.getElementById('editMemberForm').action = `/pengabdian/<%= service.id %>/anggota/${memberId}/edit`;
    document.getElementById('editMemberModal').showModal();
  }
  setTimeout(() => { document.querySelectorAll('.flash-success').forEach(el => el.style.display = 'none'); }, 5000);
</script>
