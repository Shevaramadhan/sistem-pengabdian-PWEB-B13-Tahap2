<%# GET VIEW Fitur Dosen dapat mengubah data pengabdian (Sheva Ramadhan) %>
<div class="breadcrumb">
  <a href="/pengabdian">Daftar Pengabdian</a>
  <span>/</span>
  <a href="/pengabdian/<%= service.id %>"><%= service.title %></a>
  <span>/</span>
  <span>Edit</span>
</div>

<div class="page-card mb-6" style="max-width: 800px;">
  <div class="page-card-header">
    <div>
      <h2>Edit Pengabdian</h2>
      <p>Perbarui informasi kegiatan pengabdian masyarakat.</p>
    </div>
  </div>
  
  <div class="page-card-body">
    <!-- Error Messages -->
    <% if (typeof errors !== 'undefined' && errors.length > 0) { %>
      <div class="flash-error">
        <ul>
          <% errors.forEach(err => { %>
            <li><%= err %></li>
          <% }) %>
        </ul>
      </div>
    <% } %>

    <form action="/pengabdian/<%= service.id %>/edit" method="POST">
      <div class="form-group">
        <label class="form-label" for="title">Judul Pengabdian <span style="color:red;">*</span></label>
        <input type="text" id="title" name="title" class="form-input" value="<%= service.title %>" required>
      </div>
      
      <div class="form-group">
        <label class="form-label" for="description">Deskripsi / Ringkasan</label>
        <textarea id="description" name="description" class="form-input" rows="4"><%= service.description || '' %></textarea>
      </div>
      
      <div class="form-group">
        <label class="form-label" for="location">Lokasi Pelaksanaan <span style="color:red;">*</span></label>
        <input type="text" id="location" name="location" class="form-input" value="<%= service.location %>" required>
      </div>
      
      <div class="form-grid-2">
        <div class="form-group">
          <label class="form-label" for="start_date">Tanggal Mulai <span style="color:red;">*</span></label>
          <% 
            const dStart = new Date(service.start_date);
            const startStr = !isNaN(dStart) ? dStart.toISOString().split('T')[0] : '';
          %>
          <input type="date" id="start_date" name="start_date" class="form-input" value="<%= startStr %>" required>
        </div>
        <div class="form-group">
          <label class="form-label" for="end_date">Tanggal Selesai</label>
          <% 
            let endStr = '';
            if (service.end_date) {
              const dEnd = new Date(service.end_date);
              endStr = !isNaN(dEnd) ? dEnd.toISOString().split('T')[0] : '';
            }
          %>
          <input type="date" id="end_date" name="end_date" class="form-input" value="<%= endStr %>">
        </div>
      </div>
      
      <div class="form-grid-2">
        <div class="form-group">
          <label class="form-label" for="funding_source">Sumber Pendanaan</label>
          <input type="text" id="funding_source" name="funding_source" class="form-input" value="<%= service.funding_source || '' %>">
        </div>
        <div class="form-group">
          <label class="form-label" for="status">Status</label>
          <% if (isAdmin) { %>
            <select id="status" name="status" class="form-input" required>
              <option value="proposed" <%= service.status === 'proposed' ? 'selected' : '' %>>Diusulkan (Proposed)</option>
              <option value="ongoing" <%= service.status === 'ongoing' ? 'selected' : '' %>>Sedang Berjalan (Ongoing)</option>
              <option value="completed" <%= service.status === 'completed' ? 'selected' : '' %>>Selesai (Completed)</option>
            </select>
          <% } else { %>
            <% 
              let statusLabel = 'Diusulkan';
              if (service.status === 'ongoing') statusLabel = 'Sedang Berjalan';
              if (service.status === 'completed') statusLabel = 'Selesai';
            %>
            <input type="text" class="form-input" value="<%= statusLabel %>" disabled style="background-color: #f3f4f6;">
            <input type="hidden" name="status" value="<%= service.status %>">
          <% } %>
        </div>
      </div>
      
      <div class="flex justify-end gap-3 mt-8 pt-4 border-t border-border">
        <a href="/pengabdian/<%= service.id %>" class="btn-ghost-sm" style="padding: 10px 20px;">Batal</a>
        <button type="submit" class="btn-primary" style="padding: 10px 24px;">Update Pengabdian</button>
      </div>
    </form>
  </div>
</div>
