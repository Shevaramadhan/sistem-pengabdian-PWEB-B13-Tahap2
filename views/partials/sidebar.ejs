<script>
  (function () {
    var sidebar = document.getElementById('sidebar');
    var backdrop = document.getElementById('sidebar-backdrop');

    // On mobile (<1024px), start with sidebar closed
    if (window.innerWidth < 1024) {
      sidebar.setAttribute('aria-hidden', 'true');
      sidebar.setAttribute('inert', '');
    }

    // Observe sidebar aria-hidden to toggle backdrop on mobile
    var observer = new MutationObserver(function () {
      if (window.innerWidth >= 1024) return;
      var isHidden = sidebar.getAttribute('aria-hidden') === 'true';
      backdrop.classList.toggle('active', !isHidden);
    });
    observer.observe(sidebar, { attributes: true, attributeFilter: ['aria-hidden'] });

    // Close sidebar when backdrop is clicked
    backdrop.addEventListener('click', function () {
      document.dispatchEvent(new CustomEvent('basecoat:sidebar', { detail: { action: 'close' } }));
    });

    // On resize: if going to desktop, always show sidebar and remove backdrop
    window.addEventListener('resize', function () {
      if (window.innerWidth >= 1024) {
        sidebar.setAttribute('aria-hidden', 'false');
        sidebar.removeAttribute('inert');
        backdrop.classList.remove('active');
      } else if (sidebar.getAttribute('aria-hidden') !== 'true') {
        backdrop.classList.add('active');
      }
    });
  })();
</script>