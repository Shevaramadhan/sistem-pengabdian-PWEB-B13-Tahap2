<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title><%= pageTitle %></title>
  <style>
    body { 
      font-family: Arial, sans-serif; 
      color: #000; 
      background: #fff; 
      margin: 40px; 
    }
    .header { 
      text-align: center; 
      margin-bottom: 20px; 
      border-bottom: 2px solid #000; 
      padding-bottom: 15px; 
    }
    h1 { margin: 0; font-size: 22px; text-transform: uppercase; }
    p { margin: 5px 0; font-size: 14px; }
    table { 
      width: 100%; 
      border-collapse: collapse; 
      margin-top: 20px; 
    }
    th, td { 
      border: 1px solid #000; 
      padding: 10px; 
      text-align: left; 
      font-size: 13px; 
    }
    th { 
      background-color: #f3f4f6; 
      font-weight: bold;
    }
    .no-print { 
      margin-bottom: 20px; 
      text-align: right; 
    }
    .btn-print { 
      padding: 10px 20px; 
      background: #15803d; 
      color: white; 
      border: none; 
      border-radius: 6px; 
      cursor: pointer; 
      font-size: 14px; 
      font-weight: bold;
    }
    .btn-print:hover { background: #166534; }
    
    .btn-back { 
      padding: 10px 20px; 
      background: #f3f4f6; 
      color: #374151; 
      border: 1px solid #d1d5db; 
      border-radius: 6px; 
      cursor: pointer; 
      font-size: 14px; 
      font-weight: bold;
      margin-right: 10px;
    }
    .btn-back:hover { background: #e5e7eb; }
    
    @media print {
      .no-print { display: none; }
      body { margin: 0; }
      @page { margin: 1cm; size: landscape; }
    }
  </style>
</head>
<body>

  <div class="no-print">
    <button class="btn-back" onclick="window.close() || window.history.back()">⬅️ Kembali</button>
    <button class="btn-print" onclick="window.print()">🖨️ Cetak Dokumen</button>
  </div>

  <div class="header">
    <h1>Laporan Kegiatan Pengabdian Masyarakat</h1>
    <p>Fakultas Teknologi Informasi - Universitas Andalas</p>
    <% if (search) { %>
      <p style="font-size: 13px; font-style: italic;">(Filter Pencarian: "<%= search %>")</p>
    <% } %>
  </div>

  <table>
    <thead>
      <tr>
        <th style="width: 5%; text-align: center;">No</th>
        <th style="width: 30%;">Judul Pengabdian</th>
        <th style="width: 20%;">Lokasi</th>
        <th style="width: 20%;">Dosen Pengusul</th>
        <th style="width: 10%;">Tgl Mulai</th>
        <th style="width: 15%;">Status</th>
      </tr>
    </thead>
    <tbody>
      <% if (services && services.length > 0) { %>
        <% services.forEach((service, index) => { %>
          <tr>
            <td style="text-align: center;"><%= index + 1 %></td>
            <td><%= service.title %></td>
            <td><%= service.location %></td>
            <td><%= service.creator_name %></td>
            <td><%= new Date(service.start_date).toLocaleDateString('id-ID') %></td>
            <td>
              <%= service.status === 'proposed' ? 'Diusulkan' : (service.status === 'ongoing' ? 'Berjalan' : 'Selesai') %>
            </td>
          </tr>
        <% }) %>
      <% } else { %>
        <tr>
          <td colspan="6" style="text-align: center; padding: 20px;">Tidak ada data pengabdian</td>
        </tr>
      <% } %>
    </tbody>
  </table>

  <div style="margin-top: 40px; text-align: right; font-size: 13px;">
    <p>Dicetak pada: <%= new Date().toLocaleDateString('id-ID', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></p>
  </div>

</body>
</html>
